{
  "manifest_version": 3,
  "name": "AI Chat Finder",
  "version": "1.0.2",
  "description": "Instantly search your entire AI conversation history from a single popup. 100% local, zero data transmission.",
  "permissions": [
    "alarms"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["src/content/chatgpt.ts"]
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content/claude.ts"]
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["src/content/gemini.ts"]
    },
    {
      "matches": ["https://copilot.microsoft.com/*"],
      "js": ["src/content/copilot.ts"]
    },
    {
      "matches": ["https://www.perplexity.ai/*"],
      "js": ["src/content/perplexity.ts"]
    },
    {
      "matches": ["https://grok.com/*"],
      "js": ["src/content/grok.ts"]
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["src/content/deepseek.ts"]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon-16.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  }
}
